@using Learning_Management_System.Models.ENTITIES
@model List<Students>

@{
    ViewData["Title"] = "Delete Students";
    int departmentId = ViewBag.DepartmentId != null ? (int)ViewBag.DepartmentId : 0;
    var courses = ViewBag.Courses as List<Courses> ?? new List<Courses>();
    int? selectedCourseId = ViewBag.SelectedCourseId != null ? (int?)ViewBag.SelectedCourseId : null;

    int selected = selectedCourseId ?? 0;
}

<style>
    .table-custom thead {
        background-color: royalblue !important;
        color: white;
    }

    .table-custom th, .table-custom td {
        vertical-align: middle;
    }

    .table-custom {
        border: 2px solid royalblue;
    }
</style>

<div class="container mt-4">

    @* Back button *@
    <div class="mb-3">
        <a asp-action="Index" asp-controller="Enrollments" class="btn btn-secondary">
            &larr; Back to Enrollments
        </a>
    </div>

    <h2 class="text-danger">Delete Enrolled Students</h2>

    @* TempData message *@
    @if (TempData["Message"] != null)
    {
        <div class="alert alert-info">@TempData["Message"]</div>
    }

    @* Course dropdown filter *@
    <form method="get" class="mb-3">
        <input type="hidden" name="departmentId" value="@departmentId" />
        <div class="row align-items-center">
            <div class="col-auto">
                <label for="courseSelect" class="form-label">Select Course:</label>
            </div>
            <div class="col-auto">
                <select class="form-select" id="courseSelect" name="courseId" onchange="this.form.submit()">
                    <option value="">-- All Courses --</option>
                    @foreach (var course in courses)
                    {
                        if (selected == course.CourseId)
                        {
                            <option value="@course.CourseId" selected>@course.Title</option>
                        }
                        else
                        {
                            <option value="@course.CourseId">@course.Title</option>
                        }
                    }
                </select>
            </div>
        </div>
    </form>

    @* Show message if no students *@
    @if (!Model.Any())
    {
        <div class="alert alert-warning">
            No enrolled students found for this course.
        </div>
    }
    else
    {
        <form asp-action="DeleteStudents" method="post">
            <input type="hidden" name="departmentId" value="@departmentId" />
            <input type="hidden" name="courseId" value="@selected" />

            <table class="table table-bordered table-custom">
                <thead>
                    <tr>
                        <th>Select</th>
                        <th>Student Name</th>
                        <th>Email</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var student in Model)
                    {
                        <tr>
                            <td>
                                <input type="checkbox" name="studentIds" value="@student.StudentId" />
                            </td>
                            <td>@student.Name</td>
                            <td>@student.Email</td>
                        </tr>
                    }
                </tbody>
            </table>

            <button class="btn btn-danger">Delete Selected Students</button>
            <a asp-action="Index" asp-controller="Enrollments" class="btn btn-secondary ms-2">Cancel</a>
        </form>
    }
</div>
