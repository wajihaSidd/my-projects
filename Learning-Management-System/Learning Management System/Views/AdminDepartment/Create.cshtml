@model Learning_Management_System.Models.ENTITIES.Department

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold">Add Department</h2>
        <a asp-action="Index" class="btn btn-secondary shadow-sm">← Back to Departments</a>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form asp-action="Create" method="post" class="p-4 border rounded shadow-sm bg-light">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label asp-for="Name" class="form-label fw-bold">Department Name</label>
            <input asp-for="Name" class="form-control" placeholder="Enter department name" required />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary shadow-sm">Add Department</button>
        <a asp-action="Index" class="btn btn-secondary shadow-sm">Cancel</a>
    </form>
</div>

@section Scripts {
    @@await Html.RenderPartialAsync("_ValidationScriptsPartial")
}

<style>
    .form-control {
        border-radius: 8px;
    }

    .btn {
        border-radius: 8px;
        transition: all 0.2s ease;
    }

        .btn:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }
</style>
