@model Learning_Management_System.Models.ENTITIES.Quiz

@{
    ViewData["Title"] = "Attempt Quiz";
    int questionNo = 1;
    bool alreadyAttempted = ViewBag.AlreadyAttempted ?? false;
}

@if (Model == null)
{
    <div class="alert alert-danger">
        ❌ Quiz not found.
    </div>
}
else if (alreadyAttempted)
{
    <div class="alert alert-info">
        ✅ You have already attempted this quiz.
    </div>

    <a asp-controller="QuizAttempt"
       asp-action="Index"
       class="btn btn-secondary">
        Back to Quizzes
    </a>
}
else if (Model.Questions == null || !Model.Questions.Any())
{
    <div class="alert alert-warning">
        ⚠️ No questions available for this quiz.
    </div>

    <a asp-controller="QuizAttempt"
       asp-action="Index"
       class="btn btn-secondary">
        Back to Quizzes
    </a>
}
else
{
    <h2 class="mb-3 text-primary">@Model.Title</h2>

    <div class="alert alert-warning">
        ⚠️ <strong>Important:</strong> You can attempt this quiz <b>only once</b>.
        Make sure to answer all questions before submitting.
    </div>

    <form asp-action="Attempt" method="post"
          onsubmit="return confirm('Are you sure you want to submit the quiz?');">

        @Html.AntiForgeryToken()
        <input type="hidden" name="quizId" value="@Model.QuizId" />

        @foreach (var q in Model.Questions)
        {
            <div class="card mb-4 shadow-sm">
                <div class="card-header royal-blue-header">
                    <strong>Question @questionNo</strong>
                </div>

                <div class="card-body">
                    <p class="fw-bold">@q.QuestionText</p>

                    @foreach (var option in q.Options)
                    {
                        <div class="form-check mb-2">
                            <input class="form-check-input"
                                   type="radio"
                                   name="answers[@q.QuizQuestionId]"
                                   value="@option.QuizOptionId"
                                   id="opt@option.QuizOptionId"
                                   required />

                            <label class="form-check-label"
                                   for="opt@option.QuizOptionId">
                                @option.OptionText
                            </label>
                        </div>
                    }
                </div>
            </div>

            questionNo++;
        }

        <div class="text-center">
            <button type="submit" class="btn btn-royal btn-lg">
                ✅ Submit Quiz
            </button>
        </div>
    </form>
}

<style>
    .royal-blue-header {
        background-color: royalblue !important;
        color: white !important;
    }

    .btn-royal {
        background-color: royalblue;
        color: white;
        border: none;
    }

        .btn-royal:hover {
            background-color: #27408b;
            color: white;
        }

    .form-check-input:checked {
        background-color: royalblue;
        border-color: royalblue;
    }
</style>
