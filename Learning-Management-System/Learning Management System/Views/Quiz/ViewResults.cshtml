@model IEnumerable<Learning_Management_System.Models.ENTITIES.QuizResult>

@{
    ViewData["Title"] = "Quiz Results";
    var quizId = ViewBag.QuizId;
    var courseId = Model.FirstOrDefault()?.Quiz?.CourseId ?? 0; // safely get CourseId
}

<h2>Quiz Results</h2>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">No results available yet.</div>
}
else
{
    <table class="table table-striped table-bordered">
        <thead style="background-color: royalblue; color: white;">
            <tr>
                <th>Student Name</th>
                <th>Obtained Marks</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var result in Model)
            {
                <tr style="background-color: white; color: black;">
                    <td>@(result.Student?.Name ?? "Unknown Student")</td>
                    <td>@result.ObtainedMarks</td>
                </tr>
            }
        </tbody>
    </table>
}

<a href="@Url.Action("Index", "Quiz", new { courseId = courseId })" class="btn btn-secondary mt-3">
    ← Back to Quizzes
</a>
