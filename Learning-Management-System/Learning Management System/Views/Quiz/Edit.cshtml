@model Learning_Management_System.Models.ENTITIES.Quiz
@{
    ViewData["Title"] = "Edit Quiz";
}

<h2>Edit Quiz</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="QuizId" />
    <div class="mb-3">
        <label asp-for="Title" class="form-label"></label>
        <input asp-for="Title" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="CourseId" class="form-label">Course</label>
        <select asp-for="CourseId" asp-items="ViewBag.Courses" class="form-select"></select>
    </div>
    <button type="submit" class="btn btn-primary">Save Changes</button>
</form>
