@model Learning_Management_System.Models.ENTITIES.Recap

<h2 class="text-center bg-dark text-white p-2">Course Recap - @Model.Course.Title</h2>

<table class="table table-bordered">
    <tr>
        <th>Student</th>
        <td>@Model.Student.Name - @Model.Student.RollNumber</td>
        <th>Department</th>
        <td>@Model.Student.Department?.Name</td>
    </tr>
    <tr>
        <th>Course</th>
        <td>@Model.Course.Title</td>
        <th>Instructor</th>
        <td>@Model.Course.CourseFaculty.FirstOrDefault()?.Faculty.Name</td>
    </tr>
</table>

<div class="bg-dark text-white p-2">Marks Recap</div>

<table class="table table-bordered">
    <thead class="table-primary">
        <tr>
            <th>Marks Type</th>
            <th>Max Marks</th>
            <th>Obtained Marks</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var quiz in Model.Quizzes)
        {
            <tr>
                <td>@quiz.Title</td>
                <td>@quiz.MaxMarks</td>
                <td>@(quiz.MarksObtained.HasValue? quiz.MarksObtained.ToString() : "Not Entered")</td>
            </tr>
        }

        <tr>
            <td><strong>Quiz Total</strong></td>
            <td>@Model.Quizzes.Sum(q => q.MaxMarks)</td>
            <td>@Model.Quizzes.Sum(q => q.MarksObtained ?? 0)</td>
        </tr>

        @foreach (var assignment in Model.Assignments)
        {
            <tr>
                <td>@assignment.Title</td>
                <td>@assignment.MaxMarks</td>
                <td>@(assignment.MarksObtained.HasValue? assignment.MarksObtained.ToString() : "Not Entered")</td>
            </tr>
        }

        <tr>
            <td><strong>Assignment Total</strong></td>
            <td>@Model.Assignments.Sum(a => a.MaxMarks)</td>
            <td>@Model.Assignments.Sum(a => a.MarksObtained ?? 0)</td>
        </tr>

        <tr>
            <td>Mid Exam</td>
            <td>30</td>
            <td>@(Model.MidMarks.HasValue? Model.MidMarks.ToString() : "Not Entered")</td>
        </tr>

        <tr>
            <td>Final Exam</td>
            <td>30</td>
            <td>@(Model.FinalMarks.HasValue? Model.FinalMarks.ToString() : "Not Entered")</td>
        </tr>

        <tr class="table-success">
            <td><strong>Total</strong></td>
            <td>100</td>
            <td>
                @(
                                Model.Quizzes.Sum(q => q.MarksObtained ?? 0) +
                                Model.Assignments.Sum(a => a.MarksObtained ?? 0) +
                                (Model.MidMarks ?? 0) +
                                (Model.FinalMarks ?? 0)
                                )
            </td>
        </tr>
    </tbody>
</table>
