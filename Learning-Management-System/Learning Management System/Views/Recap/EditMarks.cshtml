@model Learning_Management_System.Models.Reecap

@{
    ViewData["Title"] = "Edit Student Marks";
}

<h2 class="recap-title">Edit Marks for @Model.CourseStudent.Student.Name</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

<div class="recap-table-container">
    <form asp-action="EditMarks" method="post">
        @* Hidden field to send ReecapId *@
        <input type="hidden" asp-for="ReecapId" />

        <table class="recap-table">
            <thead>
                <tr>
                    <th>Assessment</th>
                    <th>Obtained Marks</th>
                    <th>Total Marks</th>
                </tr>
            </thead>
            <tbody>
                <tr><td>Assignment 1</td><td><input asp-for="Ass1" type="number" class="form-control mark-input" min="0" max="10" /></td><td>@Model.MaxAss1</td></tr>
                <tr><td>Assignment 2</td><td><input asp-for="Ass2" type="number" class="form-control mark-input" min="0" max="10" /></td><td>@Model.MaxAss2</td></tr>
                <tr><td>Quiz 1</td><td><input asp-for="Quiz1" type="number" class="form-control mark-input" min="0" max="10" /></td><td>@Model.MaxQuiz1</td></tr>
                <tr><td>Quiz 2</td><td><input asp-for="Quiz2" type="number" class="form-control mark-input" min="0" max="10" /></td><td>@Model.MaxQuiz2</td></tr>
                <tr><td>Mid Term</td><td><input asp-for="Mid" type="number" class="form-control mark-input" min="0" max="30" /></td><td>@Model.MaxMid</td></tr>
                <tr><td>Final Exam</td><td><input asp-for="Final" type="number" class="form-control mark-input" min="0" max="60" /></td><td>@Model.MaxFinal</td></tr>
            </tbody>
        </table>

        <div class="recap-summary mt-3">
            <h4>Total Obtained: <span>@Model.TotalMarks</span></h4>
            <h5>Total Maximum Marks: <span>@Model.TotalMaxMarks</span></h5>
        </div>

        <button type="submit" class="btn btn-success mt-3">Save Marks</button>
        <a asp-action="FacultyRecap" asp-route-courseId="@Model.CourseStudent.CourseId" class="btn btn-secondary mt-3 ms-2">Back to Courses</a>
    </form>
</div>

<style>
    .recap-title {
        background-color: royalblue;
        color: white;
        padding: 12px 20px;
        border-radius: 8px;
        font-weight: 600;
        margin-bottom: 20px;
        display: inline-block;
    }

    .recap-table-container {
        overflow-x: auto;
    }

    .recap-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        border-radius: 10px;
        overflow: hidden;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

        .recap-table th, .recap-table td {
            padding: 12px 15px;
            text-align: center;
        }

        .recap-table thead th {
            background-color: royalblue;
            color: white;
            font-weight: 600;
        }

        .recap-table tbody tr {
            background-color: #f9f9f9;
            transition: background-color 0.3s ease;
        }

            .recap-table tbody tr:nth-child(even) {
                background-color: #e9f1ff;
            }

            .recap-table tbody tr:hover {
                background-color: #d0e4ff;
            }

    .recap-summary {
        margin-top: 15px;
        font-size: 1.1rem;
    }

        .recap-summary h4, .recap-summary h5 {
            margin: 5px 0;
        }

        .recap-summary span {
            font-weight: 600;
            color: royalblue;
        }

    .form-control {
        border-radius: 6px;
    }

    /* New: reduce width of input boxes in Obtained Marks column */
    .mark-input {
        width: 160px;
        margin: 0 auto;
    }
</style>
