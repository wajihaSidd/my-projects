@model List<Learning_Management_System.Models.ViewModels.DepartmentCoursesViewModel>

<style>
    /* Headings */
    h2, h3, h4 {
        color: #0d6efd;
        font-weight: 600;
        margin-bottom: 15px;
    }

    /* Back Button */
    .btn-back {
        float: right;
        background-color: #6c757d;
        color: #fff;
        border-radius: 6px;
        padding: 7px 16px;
        margin-bottom: 20px;
        text-decoration: none;
        font-size: 14px;
        transition: background 0.25s ease;
    }

        .btn-back:hover {
            background-color: #5a6268;
            color: #fff;
            text-decoration: none;
        }

    /* Department & Course headings spacing */
    h3 {
        margin-top: 35px;
        padding-bottom: 5px;
        border-bottom: 2px solid #0d6efd33;
    }

    h4 {
        margin-top: 20px;
        margin-bottom: 10px;
        color: #0a58ca;
    }

    /* Table Styling */
    .table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        margin-bottom: 30px;
        background: #ffffff;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 3px 10px rgba(0,0,0,0.08);
    }

        .table thead th {
            background-color: #0d6efd;
            color: #fff;
            padding: 12px;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .table th,
        .table td {
            padding: 12px;
            font-size: 15px;
            border-bottom: 1px solid #e9ecef;
            vertical-align: middle;
        }

        .table tbody tr:nth-child(even) {
            background-color: #f8f9fa;
        }

        .table tbody tr:hover {
            background-color: #eef5ff;
            transition: background 0.2s ease-in-out;
        }

    /* Mobile Responsive */
    @@media (max-width: 768px) {
        .btn-back

    {
        float: none;
        display: block;
        width: 100%;
        text-align: center;
    }

    h2 {
        text-align: center;
    }

    .table th,
    .table td {
        font-size: 13px;
        padding: 10px;
    }

    h3, h4 {
        text-align: center;
    }

    }
</style>


<h2 class="mb-4 text-primary">
    Attendance Records
    <a asp-controller="AdminDashboard" asp-action="Index" class="btn btn-back">Back</a>
</h2>

@foreach (var dept in Model)
{
    <h3>@dept.Department.Name</h3>

    @foreach (var courseInfo in dept.Courses)
    {
        <h4>Course: @courseInfo.Course.Title</h4>

        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Student</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Faculty</th>
                    <th>Remarks</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cs in courseInfo.Course.CourseStudents)
                {
                    var student = cs.Student;
                    var records = courseInfo.Course.Attendance
                    .Where(a => a.StudentId == student.StudentId)
                    .OrderBy(a => a.Date)
                    .ToList();

                    if (records.Count == 0)
                    {
                        <tr>
                            <td>@student.Name</td>
                            <td colspan="4">No attendance recorded</td>
                        </tr>
                    }
                    else
                    {
                        bool firstRow = true;
                        foreach (var r in records)
                        {
                            <tr>
                                @if (firstRow)
                                {
                                    <td rowspan="@records.Count">@student.Name</td>
                                    firstRow = false;
                                }
                                <td>@r.Date.ToShortDateString()</td>
                                <td>@r.Status</td>
                                <td>@r.Faculty.Name</td>
                                <td>@r.Remarks</td>
                            </tr>
                        }
                    }
                }
            </tbody>
        </table>
    }
}