@model IEnumerable<Learning_Management_System.Models.ENTITIES.Courses>

@{
    ViewData["Title"] = "Current Semester Courses";
}

<h2 class="recap-title">Your Current Semester Courses</h2>

<!-- All Courses Attendance Button -->
<div class="mb-3">
    <a asp-controller="Attendance" asp-action="StudentView"
       class="btn all-attendance-btn">
        📊 View All Courses Attendance
    </a>
</div>

@if (Model != null && Model.Any())
{
    <div class="courses-container">
        @foreach (var course in Model)
        {
            <div class="course-card">
                <table class="course-table">
                    <thead>
                        <tr>
                            <th>@course.Title</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>
                                <div class="btn-group-wrapper">
                                    <!-- Student Outline Link -->
                                    <a asp-controller="CourseOutline" asp-action="StudentView" asp-route-courseId="@course.CourseId" class="btn btn-info btn-sm">
                                        Outline
                                    </a>

                                    <!-- Recap button -->
                                    <a asp-controller="Recap"
                                       asp-action="StudentView"
                                       asp-route-courseId="@course.CourseId"
                                       class="btn btn-warning btn-sm">
                                        Recap
                                    </a>

                                    <!-- Attendance button -->
                                    <a asp-controller="Attendance"
                                       asp-action="StudentView"
                                       asp-route-courseId="@course.CourseId"
                                       class="btn btn-success btn-sm">
                                        Attendance
                                    </a>

                                    <!-- Files button -->
                                    <a asp-controller="CourseFiles"
                                       asp-action="StudentViewFiles"
                                       asp-route-courseId="@course.CourseId"
                                       class="btn btn-dark btn-sm">
                                        Files
                                    </a>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info">You have no courses in this semester.</div>
}

<style>
    /* Page Title */
    .recap-title {
        background-color: royalblue;
        color: white;
        padding: 12px 20px;
        border-radius: 8px;
        font-weight: 600;
        margin-bottom: 20px;
        display: inline-block;
    }

    /* All Courses Attendance Button */
    .all-attendance-btn {
        display: inline-block;
        padding: 8px 15px;
        background-color: #007bff;
        color: white;
        text-decoration: none;
        border-radius: 5px;
        transition: background-color 0.2s ease;
    }

        .all-attendance-btn:hover {
            background-color: #0069d9;
        }

    /* Courses Container */
    .courses-container {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    /* Individual Course Card */
    .course-card {
        background-color: #f1f8ff;
        border-radius: 10px;
        box-shadow: 0 3px 8px rgba(0,0,0,0.1);
        overflow: hidden;
        transition: transform 0.2s ease;
    }

        .course-card:hover {
            transform: translateY(-3px);
        }

    /* Table inside course card */
    .course-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

        .course-table th {
            background-color: royalblue;
            color: white;
            padding: 10px 15px;
            font-weight: 600;
            text-align: left;
        }

    /* Button group inside table */
    .btn-group-wrapper {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

        .btn-group-wrapper .btn {
            min-width: 80px;
            text-align: center;
            font-weight: 600;
        }
</style>
