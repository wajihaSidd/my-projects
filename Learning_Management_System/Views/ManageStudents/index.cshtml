@model IEnumerable<Learning_Management_System.Models.ENTITIES.Students>

@{
    ViewData["Title"] = "Index";
}

<h1>List Of Students</h1>

<p>
    <a asp-action="Create" class="btn btn-success">Create New</a>
</p>

<!-- Student Table -->
<table class="dashboard-table">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.StudentId)</th>
            <th>@Html.DisplayNameFor(model => model.Name)</th>
            <th>@Html.DisplayNameFor(model => model.RollNumber)</th>
            @*<th>@Html.DisplayNameFor(model => model.Course)</th>*@
            <th>@Html.DisplayNameFor(model => model.Percentage)</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var student in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => student.StudentId)</td>
                <td>@Html.DisplayFor(modelItem => student.Name)</td>
                <td>@Html.DisplayFor(modelItem => student.RollNumber)</td>
                @*<td>@Html.DisplayFor(modelItem => student.Course)</td>*@
                <td>@Html.DisplayFor(modelItem => student.Percentage)</td>
                <td class="actions">
                    <a asp-action="Edit" asp-route-id="@student.StudentId" class="btn btn-primary btn-sm">Edit</a>
                    <a asp-action="Details" asp-route-id="@student.StudentId" class="btn btn-info btn-sm">Details</a>
                    <a asp-action="Delete" asp-route-id="@student.StudentId" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Embedded CSS for Dashboard Table -->
<style>
    h1 {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: #333;
        margin-bottom: 20px;
    }

    .btn {
        text-decoration: none;
        padding: 6px 12px;
        border-radius: 5px;
        margin-right: 5px;
        color: white;
        font-size: 0.9rem;
    }

    .btn-success {
        background-color: #28a745;
    }

    .btn-primary {
        background-color: #007bff;
    }

    .btn-info {
        background-color: #17a2b8;
    }

    .btn-danger {
        background-color: #dc3545;
    }

    .dashboard-table {
        width: 100%;
        border-collapse: collapse;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        margin-top: 15px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

        .dashboard-table th,
        .dashboard-table td {
            padding: 12px 15px;
            text-align: left;
        }

        .dashboard-table thead {
            background-color: #f5f5f5;
            border-bottom: 2px solid #dee2e6;
        }

        .dashboard-table tbody tr {
            background-color: #fff;
            transition: background-color 0.3s ease;
        }

            .dashboard-table tbody tr:nth-child(even) {
                background-color: #f9f9f9;
            }

            .dashboard-table tbody tr:hover {
                background-color: #e9f5ff;
            }

        .dashboard-table td.actions a {
            margin-right: 5px;
        }
</style>
