@model IEnumerable<Learning_Management_System.Models.ENTITIES.Courses>

<h2 class="recap-title">Select Your Assigned Course</h2>

<div class="recap-card">
    <div class="card-body">
        <div class="recap-table-container">
            <table class="recap-table">
                <thead>
                    <tr>
                        <th>Course Title</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var course in Model)
                    {
                        <tr>
                            <td>@course.Title</td>
                            <td>
                                <a asp-action="FacultyCourseAttendance" asp-route-courseId="@course.CourseId" class="btn btn-info btn-sm recap-btn">
                                    View Attendance
                                </a>
                                <a asp-action="Mark" asp-route-courseId="@course.CourseId" class="btn btn-success btn-sm recap-btn">
                                    Mark Attendance
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-controller="FacultyDashboard"
       asp-action="Index"
       class="btn back-btn">
        <i class="fas fa-arrow-left"></i> Back to Dashboard
    </a>
</div>

<style>
    /* Card container */
    .recap-card {
        border-radius: 10px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        margin-bottom: 20px;
        background-color: white;
        border: none;
    }

    /* Recap-style title */
    .recap-title {
        background-color: royalblue;
        color: white;
        padding: 12px 20px;
        border-radius: 8px;
        font-weight: 600;
        margin-bottom: 20px;
        display: inline-block;
    }

    /* Table container */
    .recap-table-container {
        overflow-x: auto;
    }

    .recap-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        border-radius: 10px;
        overflow: hidden;
    }

        .recap-table th, .recap-table td {
            padding: 12px 15px;
            text-align: center;
        }

        .recap-table thead th {
            background-color: royalblue;
            color: white;
            font-weight: 600;
        }

        .recap-table tbody tr {
            background-color: #f9f9f9;
            transition: background-color 0.3s ease, transform 0.2s ease;
        }

            .recap-table tbody tr:nth-child(even) {
                background-color: #e9f1ff;
            }

            .recap-table tbody tr:hover {
                background-color: #d0e4ff;
                transform: scale(1.01);
            }

    /* Buttons inside table */
    .recap-btn {
        padding: 6px 12px;
        font-weight: 600;
        border-radius: 6px;
        color: white;
        text-decoration: none;
        margin-right: 5px;
        transition: background-color 0.2s, transform 0.2s;
    }

    .btn-info.recap-btn {
        background-color: #0d6efd;
        border: none;
    }

        .btn-info.recap-btn:hover {
            background-color: #0b5ed7;
            transform: translateY(-1px);
        }

    .btn-success.recap-btn {
        background-color: #28a745;
        border: none;
    }

        .btn-success.recap-btn:hover {
            background-color: #218838;
            transform: translateY(-1px);
        }

    /* Back button */
    .back-btn {
        padding: 10px 20px;
        background-color: #6c757d;
        color: white;
        border-radius: 6px;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        transition: background-color 0.2s ease;
    }

        .back-btn:hover {
            background-color: #5a6268;
        }
</style>
