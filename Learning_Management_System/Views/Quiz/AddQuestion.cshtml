@model Learning_Management_System.Models.ENTITIES.Quiz

@{
    ViewData["Title"] = "Add Question";
}

<h2>Add Question to Quiz: @Model.Title</h2>



<form asp-action="AddQuestion" method="post">
    <input type="hidden" name="quizId" value="@Model.QuizId" />

    <div class="mb-3">
        <label class="form-label">Question Text</label>
        <textarea class="form-control" name="questionText" required></textarea>
    </div>

    <h5>Options</h5>
    @for (int i = 0; i < 4; i++)
    {
        <div class="mb-2">
            <input type="text" class="form-control" name="options" placeholder="Option @(@i + 1)" required />
            <label>
                <input type="checkbox" name="isCorrect" value="@i" /> Correct
            </label>
        </div>
    }

    <button type="submit" class="btn btn-primary">Add Question</button>
</form>

<hr />

<h3 class="mt-4">Already Added Questions</h3>
@if (Model.Questions != null && Model.Questions.Any())
{
    <div class="list-group">
        @foreach (var q in Model.Questions.OrderBy(q => q.QuizQuestionId))
        {
            <div class="list-group-item mb-2">
                <strong>@q.QuestionText</strong>
                <ul class="mt-2">
                    @foreach (var opt in q.Options)
                    {
                        <li>
                            @opt.OptionText
                            @if (opt.IsCorrect)
                            {
                                <span class="badge bg-success">Correct</span>
                            }
                        </li>
                    }
                </ul>
            </div>
        }
    </div>

    <a asp-action="Index" asp-route-courseId="@Model.CourseId" class="btn btn-secondary mb-3">
        ← Back to Quiz List
    </a>
}
else
{
    <div class="alert alert-info">No questions added yet.</div>

    <a asp-action="Index" asp-route-courseId="@Model.CourseId" class="btn btn-secondary mb-3">
        ← Back to Quiz List
    </a>
}
