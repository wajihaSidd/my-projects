@model IEnumerable<Learning_Management_System.Models.ENTITIES.Department>

@{
    ViewData["Title"] = "Departments";
}

<div class="container mt-4">
    <h2 class="fw-bold text-primary mb-3">Departments</h2>

    <div class="mb-3">
        <a asp-action="Create" class="btn btn-success">+ Add Department</a>
    </div>

    <table class="table table-striped table-bordered shadow">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var dept in Model)
            {
                <tr>
                    <td>@dept.Name</td>
                    <td class="text-center">
                        <a asp-action="OfferCourses" asp-route-departmentId="@dept.DepartmentId" class="btn btn-primary btn-sm">
                            Offer Courses
                        </a>
                        <a asp-action="Edit" asp-route-id="@dept.DepartmentId" class="btn btn-warning btn-sm">
                            Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@dept.DepartmentId" class="btn btn-danger btn-sm"
                           onclick="return confirm('Are you sure you want to delete this department?');">
                            Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<style>
    .table th, .table td {
        vertical-align: middle;
    }

    .btn-sm {
        margin: 0 2px;
    }
</style>
