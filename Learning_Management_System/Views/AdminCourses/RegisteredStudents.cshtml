@model IEnumerable<Learning_Management_System.Models.ENTITIES.Students>

@{
    ViewData["Title"] = "Registered Students";
    var courseTitle = ViewBag.CourseTitle as string;
}

<div class="container mt-4">
    <h2 class="fw-bold text-primary mb-3">Registered Students for @courseTitle</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    @if (Model != null && Model.Any())
    {
        <table class="table table-striped table-bordered shadow">
            <thead class="table-dark">
                <tr>
                    <th>Student ID</th>
                    <th>Name</th>
                    <th>Roll Number</th>
                    <th>Email</th>
                    <th>Department</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var student in Model)
                {
                    <tr>
                        <td>@student.StudentId</td>
                        <td>@student.Name</td>
                        <td>@student.RollNumber</td>
                        <td>@student.Email</td>
                        <td>@(student.Department != null ? student.Department.Name : "N/A")</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="mt-3">
            <strong>Total Students Registered: @Model.Count()</strong>
        </div>
    }
    else
    {
        <div class="alert alert-info">No students registered for this course yet.</div>
    }

    <a asp-action="Index" asp-controller="AdminCourse" class="btn btn-secondary mt-3">Back to Courses</a>
</div>

<style>
    .table th, .table td {
        vertical-align: middle;
    }
</style>
